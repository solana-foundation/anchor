---
import '@/styles/global.css'
import '@/styles/typography.css'
import '@/styles/tab-panels.css'
import '@/styles/toc.css'
import '@/styles/doc-meta.css'

import AnnouncementBar from '@/components/docs/announcement-bar.astro'
import Search from '@/components/docs/search.astro'
import Head from '@/components/head.astro'
import { DOCS, SITE } from '@/consts'
---

<!doctype html>
<html class="bg-background text-foreground scheme-light-dark" lang={SITE.locale}>
  <Head>
    <slot name="head" />
  </Head>
  <body class="flex min-h-screen flex-col font-sans">
    <AnnouncementBar />
    <slot />
    {DOCS.search.enabled && <Search />}

    <script>
      import { mountInlineShellCopy } from '@/lib/client/inline-shell-copy'

      mountInlineShellCopy()
    </script>
  </body>
</html>
