---
import SidebarBadge from '@/components/docs/sidebar-badge.astro'
import Link from '@/components/link.astro'
import { cn, trimTrailingSlash } from '@/lib/utils'
import { getDocsVersionSwitchOptions } from '@/lib/sidebar'

const options = await getDocsVersionSwitchOptions(Astro.url.pathname)
const currentPath = trimTrailingSlash(Astro.url.pathname)
---

<nav
  aria-label="Documentation version"
  class="border-border/80 bg-muted/30 grid grid-cols-2 gap-1 rounded-md border p-1"
>
  {
    options.map((option) => (
      <Link
        href={option.href}
        aria-current={
          option.active && trimTrailingSlash(option.href) === currentPath ? 'page' : undefined
        }
        data-version-option={option.version}
        data-active={option.active ? 'true' : undefined}
        class={cn(
          'text-muted-foreground hover:bg-muted/60 hover:text-foreground flex min-h-8 items-center justify-center gap-1.5 rounded-sm px-2 text-sm font-medium no-underline transition-colors',
          'data-[active=true]:bg-background data-[active=true]:text-foreground data-[active=true]:shadow-xs data-[active=true]:hover:bg-background data-[active=true]:hover:text-foreground',
        )}
      >
        <span>{option.label}</span>
        {option.badge && <SidebarBadge badge={option.badge} />}
      </Link>
    ))
  }
</nav>

<script>
  type DocsVersion = 'v1' | 'v2'

  const STORAGE_KEY = 'anchor-docs-version'
  const BASE_PATH = import.meta.env.BASE_URL.replace(/\/$/, '')

  function versionFromPath(path: string): DocsVersion | null {
    if (path === `${BASE_PATH}/v1` || path.startsWith(`${BASE_PATH}/v1/`)) return 'v1'
    if (path === `${BASE_PATH}/v2` || path.startsWith(`${BASE_PATH}/v2/`)) return 'v2'
    return null
  }

  function versionFromUrl(): DocsVersion {
    const pathVersion = versionFromPath(window.location.pathname)
    if (pathVersion) return pathVersion

    const params = new URLSearchParams(window.location.search)
    const queryVersion = params.get('version')
    if (queryVersion === 'v1' || queryVersion === 'v2') return queryVersion

    const stored = localStorage.getItem(STORAGE_KEY)
    return stored === 'v1' || stored === 'v2' ? stored : 'v2'
  }

  function applyVersionFocus() {
    const version = versionFromUrl()
    localStorage.setItem(STORAGE_KEY, version)

    document.querySelectorAll<HTMLElement>('[data-version-sidebar]').forEach((sidebar) => {
      sidebar.hidden = sidebar.dataset.versionSidebar !== version
    })

    document.querySelectorAll<HTMLAnchorElement>('[data-version-option]').forEach((option) => {
      const active = option.dataset.versionOption === version
      if (active) option.dataset.active = 'true'
      else option.removeAttribute('data-active')

      const optionUrl = new URL(option.href)
      const samePath =
        optionUrl.pathname.replace(/\/+$/, '') === window.location.pathname.replace(/\/+$/, '')
      if (active && samePath) option.setAttribute('aria-current', 'page')
      else option.removeAttribute('aria-current')
    })
  }

  function setupVersionSwitcher() {
    applyVersionFocus()

    document.querySelectorAll<HTMLAnchorElement>('[data-version-option]').forEach((option) => {
      option.addEventListener('click', () => {
        const version = option.dataset.versionOption
        if (version === 'v1' || version === 'v2') localStorage.setItem(STORAGE_KEY, version)
      })
    })
  }

  setupVersionSwitcher()
  document.addEventListener('astro:after-swap', setupVersionSwitcher)
</script>
