---
import { BANNER_GRAPHICS, getBannerGraphic, type BannerGraphic } from '@/lib/banner-graphics'
import { withBase } from '@/lib/docs'
import { cn } from '@/lib/utils'

interface Props {
  banner: string
  size?: 'full' | 'compact'
}

const { banner, size = 'full' } = Astro.props
const isRandom = banner === 'random'
const fallback = isRandom ? BANNER_GRAPHICS[0] : getBannerGraphic(banner)
const graphics = (isRandom ? BANNER_GRAPHICS : [fallback]).map((graphic) => ({
  ...graphic,
  src: withBase(graphic.src),
}))
const initialGraphic = graphics[0] as BannerGraphic
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<figure
  class={cn(
    'not-prose group relative overflow-hidden bg-muted xl:ml-4',
    size === 'compact' ? 'h-36 sm:h-[11rem] xl:h-[12.5rem]' : 'h-72 sm:h-[22rem] xl:h-[25rem]',
  )}
  data-pagefind-ignore
  data-doc-banner
  data-random-banner={isRandom ? 'true' : 'false'}
  data-banner-size={size}
  data-banner-options={JSON.stringify(graphics)}
>
  <img
    src={initialGraphic.src}
    alt={initialGraphic.description}
    title={`${initialGraphic.title} by ${initialGraphic.artist}`}
    class="size-full object-cover"
    style={`object-position: ${initialGraphic.objectPosition}`}
    data-banner-image
  />
  <figcaption
    class="absolute right-3 bottom-3 max-w-[calc(100%-1.5rem)] rounded-md bg-background/80 px-2 py-1 text-[0.6875rem] leading-tight text-muted-foreground opacity-0 shadow-sm backdrop-blur-sm transition-opacity group-hover:opacity-100 focus-within:opacity-100"
  >
    <span data-banner-title>{initialGraphic.title}</span>
    <span aria-hidden="true"> · </span>
    <span data-banner-artist>{initialGraphic.artist}</span>
  </figcaption>
</figure>

<script is:inline data-astro-rerun define:vars={{ basePath }}>
  ;(() => {
    function pickWeightedBanner(options) {
      const totalWeight = options.reduce((sum, option) => {
        const weight = Number(option.weight)
        return sum + (Number.isFinite(weight) && weight > 0 ? weight : 0)
      }, 0)

      if (totalWeight <= 0) return options[0]

      const random = Math.random() * totalWeight
      let cursor = 0

      return (
        options.find((option) => {
          const weight = Number(option.weight)
          cursor += Number.isFinite(weight) && weight > 0 ? weight : 0
          return random <= cursor
        }) || options[0]
      )
    }

    function applyBanner(banner, selected) {
      const image = banner.querySelector('[data-banner-image]')
      const title = banner.querySelector('[data-banner-title]')
      const artist = banner.querySelector('[data-banner-artist]')

      banner.dataset.bannerGraphicId = selected.id

      if (image instanceof HTMLImageElement) {
        image.src = selected.src
        image.alt = selected.description
        image.title = `${selected.title} by ${selected.artist}`
        image.style.objectPosition = selected.objectPosition
      }

      if (title) title.textContent = selected.title
      if (artist) artist.textContent = selected.artist
    }

    function setupRandomDocBanner(root = document, preferredGraphicId = '') {
      const banners = root.querySelectorAll('[data-doc-banner][data-random-banner="true"]')

      banners.forEach((banner) => {
        let options = []
        try {
          options = JSON.parse(banner.getAttribute('data-banner-options') || '[]')
        } catch {}

        if (!Array.isArray(options) || options.length === 0) return

        const selected =
          options.find((option) => option.id === preferredGraphicId) ||
          options.find((option) => option.id === banner.dataset.bannerGraphicId) ||
          pickWeightedBanner(options)

        applyBanner(banner, selected)
      })
    }

    function isDocsHomeUrl(url) {
      const pathname = new URL(url, window.location.href).pathname.replace(/\/+$/, '')
      return pathname === basePath
    }

    function isHomeDocsTransition(fromUrl, toUrl) {
      const fromHome = isDocsHomeUrl(fromUrl)
      const toHome = isDocsHomeUrl(toUrl)

      return fromHome !== toHome
    }

    setupRandomDocBanner()

    if (!window.__anchorRandomDocBannerReady) {
      window.__anchorRandomDocBannerReady = true
      document.addEventListener('astro:before-swap', (event) => {
        const currentBanner = document.querySelector('[data-doc-banner]')
        const preferredGraphicId = isHomeDocsTransition(event.from, event.to)
          ? currentBanner?.dataset.bannerGraphicId || ''
          : ''

        setupRandomDocBanner(event.newDocument, preferredGraphicId)
      })
      document.addEventListener('astro:after-swap', () => {
        setupRandomDocBanner()
      })
    }
  })()
</script>
