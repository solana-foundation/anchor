---
import { BANNER_GRAPHICS, DEFAULT_BANNER_GRAPHIC, getBannerGraphic } from '@/lib/banner-graphics'
import { withBase } from '@/lib/docs'
import { cn } from '@/lib/utils'

interface Props {
  banner: string
  size?: 'full' | 'compact'
}

const { banner, size = 'full' } = Astro.props
const isRandom = banner === 'random'
const fallback = isRandom ? DEFAULT_BANNER_GRAPHIC : getBannerGraphic(banner)
const graphics = (isRandom ? BANNER_GRAPHICS : [fallback]).map((graphic) => ({
  ...graphic,
  src: withBase(graphic.src),
}))
const initialGraphic = graphics[0] ?? { ...fallback, src: withBase(fallback.src) }
---

<figure
  class={cn(
    'not-prose group relative overflow-hidden bg-muted xl:ml-4',
    size === 'compact' ? 'h-36 sm:h-[11rem] xl:h-[12.5rem]' : 'h-72 sm:h-[22rem] xl:h-[25rem]',
  )}
  data-pagefind-ignore
  data-doc-banner
  data-random-banner={isRandom ? 'true' : 'false'}
  data-banner-size={size}
  data-banner-options={JSON.stringify(graphics)}
>
  <img
    src={initialGraphic.src}
    alt={initialGraphic.description}
    title={`${initialGraphic.title} by ${initialGraphic.artist}`}
    class="size-full object-cover"
    style={`object-position: ${initialGraphic.objectPosition}`}
    data-banner-image
  />
  <figcaption
    class="absolute right-3 bottom-3 max-w-[calc(100%-1.5rem)] rounded-md bg-background/80 px-2 py-1 text-[0.6875rem] leading-tight text-muted-foreground opacity-0 shadow-sm backdrop-blur-sm transition-opacity group-hover:opacity-100 focus-within:opacity-100"
  >
    <span data-banner-title>{initialGraphic.title}</span>
    <span aria-hidden="true"> · </span>
    <span data-banner-artist>{initialGraphic.artist}</span>
  </figcaption>
</figure>

<script>
  import { mountRandomDocBanners } from '@/lib/client/random-banner'

  mountRandomDocBanners()
</script>
