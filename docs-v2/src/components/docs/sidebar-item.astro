---
import SidebarBadge from '@/components/docs/sidebar-badge.astro'
import Link from '@/components/link.astro'
import { cn } from '@/lib/utils'
import type { SidebarNode } from '@/types'
import { Icon } from 'astro-icon/components'

interface Props {
  node: SidebarNode
  depth?: number
}

const { node, depth = 0 } = Astro.props
---

{
  node.type === 'link' ? (
    <Link
      href={node.href}
      data-sidebar-link={node.href}
      aria-current={node.isCurrent ? 'page' : undefined}
      class={cn(
        'flex items-center justify-between gap-2 rounded-md px-2 py-1 text-sm no-underline',
        'text-muted-foreground hover:bg-muted/50 hover:text-foreground',
        'aria-[current=page]:bg-[color-mix(in_oklch,var(--accent)_12%,transparent)]',
        'aria-[current=page]:text-accent aria-[current=page]:font-medium',
        'aria-[current=page]:hover:bg-[color-mix(in_oklch,var(--accent)_18%,transparent)]',
        'aria-[current=page]:hover:text-accent',
      )}
    >
      <span class="break-words">{node.label}</span>
      {node.badge && <SidebarBadge badge={node.badge} />}
    </Link>
  ) : node.forceOpen ? (
    <div data-sidebar-group data-force-open data-group-path={node.label}>
      <div
        class={cn(
          'text-foreground flex items-center justify-between gap-2 rounded-md px-2 py-1 text-sm font-medium select-none',
        )}
      >
        <span class="flex min-w-0 items-center gap-2">
          <span class="break-words">{node.label}</span>
          {node.badge && <SidebarBadge badge={node.badge} />}
        </span>
      </div>
      <ul class="border-border/70 mt-1 ml-3 flex flex-col gap-0.5 border-l pl-2">
        {node.items.map((child) => (
          <li>
            <Astro.self node={child} depth={depth + 1} />
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <details
      open={!node.collapsed}
      data-sidebar-group
      data-group-path={node.label}
      class="group"
    >
      <summary
        class={cn(
          'text-foreground flex cursor-pointer list-none items-center justify-between gap-2 rounded-md px-2 py-1 text-sm font-medium select-none',
          'hover:bg-muted/50 [&::-webkit-details-marker]:hidden',
        )}
      >
        <span class="flex min-w-0 items-center gap-2">
          <span class="break-words">{node.label}</span>
          {node.badge && <SidebarBadge badge={node.badge} />}
        </span>
        <Icon
          name="lucide:chevron-right"
          class="text-muted-foreground size-4 shrink-0 transition-transform duration-200 group-open:rotate-90"
        />
      </summary>
      <ul class={cn('border-border/70 mt-1 ml-3 flex flex-col gap-0.5 border-l pl-2')}>
        {node.items.map((child) => (
          <li>
            <Astro.self node={child} depth={depth + 1} />
          </li>
        ))}
      </ul>
    </details>
  )
}
