---
import SidebarItem from '@/components/docs/sidebar-item.astro'
import { ScrollArea } from '@/components/ui/scroll-area'
import type { SidebarNode } from '@/types'

interface Props {
  tree: SidebarNode[]
  class?: string
}

const { tree, class: className } = Astro.props
---

<nav aria-label="Documentation" class={className}>
  <ScrollArea client:load className="h-full" type="hover">
    <ul class="flex flex-col gap-0.5">
      {
        tree.map((node) => (
          <li>
            <SidebarItem node={node} />
          </li>
        ))
      }
    </ul>
  </ScrollArea>
</nav>

<script>
  const SIDEBAR_GROUP_STATE_KEY = 'anchor-docs-sidebar-groups'
  const SIDEBAR_SCROLL_STATE_KEY = 'anchor-docs-sidebar-scroll'
  const SIDEBAR_PENDING_SCROLL_KEY = 'anchor-docs-sidebar-pending-scroll'

  function trimTrailingSlash(path: string): string {
    if (path === '/') return path
    return path.replace(/\/+$/, '')
  }

  function readSidebarGroupState(): Record<string, boolean> {
    try {
      const value = localStorage.getItem(SIDEBAR_GROUP_STATE_KEY)
      return value ? JSON.parse(value) : {}
    } catch {
      return {}
    }
  }

  function writeSidebarGroupState(state: Record<string, boolean>) {
    localStorage.setItem(SIDEBAR_GROUP_STATE_KEY, JSON.stringify(state))
  }

  function readSidebarScrollState(): Record<string, number> {
    try {
      const value = localStorage.getItem(SIDEBAR_SCROLL_STATE_KEY)
      return value ? JSON.parse(value) : {}
    } catch {
      return {}
    }
  }

  function writeSidebarScrollState(state: Record<string, number>) {
    localStorage.setItem(SIDEBAR_SCROLL_STATE_KEY, JSON.stringify(state))
  }

  function getSidebarGroupKey(group: HTMLElement): string | null {
    const key = group.dataset.groupPath
    return key && key.length > 0 ? key : null
  }

  let syncingSidebarGroups = false

  function setMatchingSidebarGroups(key: string, open: boolean, source: HTMLDetailsElement) {
    syncingSidebarGroups = true
    document
      .querySelectorAll<HTMLDetailsElement>(`details[data-sidebar-group][data-group-path="${CSS.escape(key)}"]`)
      .forEach((group) => {
        if (group !== source) group.open = open
      })
    syncingSidebarGroups = false
  }

  function restoreSidebarGroups() {
    const state = readSidebarGroupState()
    document
      .querySelectorAll<HTMLDetailsElement>('details[data-sidebar-group][data-group-path]')
      .forEach((group) => {
        const key = getSidebarGroupKey(group)
        if (!key || state[key] === undefined) return
        group.open = state[key]
      })
  }

  function setupPersistentSidebarGroups() {
    restoreSidebarGroups()

    document
      .querySelectorAll<HTMLDetailsElement>('details[data-sidebar-group][data-group-path]')
      .forEach((group) => {
        if (group.dataset.sidebarPersistenceBound === 'true') return
        group.dataset.sidebarPersistenceBound = 'true'

        group.addEventListener('toggle', () => {
          if (syncingSidebarGroups) return
          const key = getSidebarGroupKey(group)
          if (!key) return

          const state = readSidebarGroupState()
          state[key] = group.open
          writeSidebarGroupState(state)
          setMatchingSidebarGroups(key, group.open, group)
        })
      })
  }

  function isHidden(element: HTMLElement): boolean {
    return Boolean(element.closest('[hidden]')) || element.getClientRects().length === 0
  }

  function getSidebarViewports(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>('nav[aria-label="Documentation"] [data-slot="scroll-area-viewport"]'))
  }

  function getSidebarScrollKey(viewport: HTMLElement): string {
    const version = viewport.closest<HTMLElement>('[data-version-sidebar]')?.dataset.versionSidebar ?? 'default'
    const placement = viewport.closest('#mobile-sidebar') ? 'mobile' : 'desktop'
    return `${placement}:${version}`
  }

  function saveSidebarViewportScroll(viewport: HTMLElement) {
    const state = readSidebarScrollState()
    state[getSidebarScrollKey(viewport)] = viewport.scrollTop
    writeSidebarScrollState(state)
  }

  function saveVisibleSidebarScrolls() {
    getSidebarViewports().forEach((viewport) => {
      if (!isHidden(viewport)) saveSidebarViewportScroll(viewport)
    })
  }

  function readPendingSidebarScroll(): number | null {
    const value = sessionStorage.getItem(SIDEBAR_PENDING_SCROLL_KEY)
    if (value === null) return null

    const scrollTop = Number(value)
    return Number.isFinite(scrollTop) ? scrollTop : null
  }

  function restoreSidebarScrolls() {
    const pendingScrollTop = readPendingSidebarScroll()
    const state = readSidebarScrollState()
    let usedPendingScroll = false

    getSidebarViewports().forEach((viewport) => {
      if (isHidden(viewport)) return

      const scrollTop = pendingScrollTop ?? state[getSidebarScrollKey(viewport)]
      if (typeof scrollTop !== 'number') return

      viewport.scrollTop = Math.max(0, Math.min(scrollTop, viewport.scrollHeight - viewport.clientHeight))
      if (pendingScrollTop !== null) usedPendingScroll = true
    })

    if (usedPendingScroll) sessionStorage.removeItem(SIDEBAR_PENDING_SCROLL_KEY)
  }

  function setupPersistentSidebarScrolls() {
    restoreSidebarScrolls()

    getSidebarViewports().forEach((viewport) => {
      if (viewport.dataset.sidebarScrollBound === 'true') return
      viewport.dataset.sidebarScrollBound = 'true'

      viewport.addEventListener('scroll', () => saveSidebarViewportScroll(viewport), {
        passive: true,
      })
    })
  }

  function updateActiveSidebarLink() {
    const current = trimTrailingSlash(window.location.pathname)
    document.querySelectorAll<HTMLAnchorElement>('[data-sidebar-link]').forEach((link) => {
      const href = link.getAttribute('data-sidebar-link') ?? ''
      const isActive = trimTrailingSlash(href) === current
      if (isActive) {
        link.setAttribute('aria-current', 'page')
        // Expand every <details> ancestor so the active link is visible.
        let node: HTMLElement | null = link.parentElement
        while (node) {
          if (node instanceof HTMLDetailsElement) node.open = true
          node = node.parentElement
        }
      } else {
        link.removeAttribute('aria-current')
      }
    })
  }

  function setupSidebar() {
    setupPersistentSidebarGroups()
    updateActiveSidebarLink()
    setupPersistentSidebarScrolls()
  }

  setupSidebar()
  document.addEventListener('astro:before-swap', saveVisibleSidebarScrolls)
  document.addEventListener('astro:after-swap', setupSidebar)
  window.addEventListener('anchor-docs:version-focus', restoreSidebarScrolls)
</script>
