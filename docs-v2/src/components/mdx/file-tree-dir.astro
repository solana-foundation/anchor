---
import { Icon } from 'astro-icon/components'

interface Props {
  name: string
  open?: boolean
  highlight?: boolean
  comment?: string
}

const { name, open = true, highlight = false, comment } = Astro.props
const hasChildren = Astro.slots.has('default')
---

{
  hasChildren ? (
    <li>
      <details class="group" open={open || undefined}>
        <summary
          class:list={[
            'inline-flex cursor-pointer list-none select-none items-center gap-1.5 whitespace-nowrap rounded px-1.5 py-0.5 hover:bg-muted/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring',
            highlight && 'bg-primary/10 font-medium text-primary',
          ]}
        >
          <Icon
            name="lucide:chevron-right"
            class="text-muted-foreground size-3 shrink-0 transition-transform group-open:rotate-90"
          />
          <Icon name="lucide:folder" class="size-4 shrink-0 text-muted-foreground" />
          <span class="font-mono">{name}/</span>
          {comment && <span class="text-muted-foreground/75 ml-2">{comment}</span>}
        </summary>
        <ul class="mt-0.5 ml-[11px] list-none space-y-0.5 border-l-2 pl-3">
          <slot />
        </ul>
      </details>
    </li>
  ) : (
    <li>
      <span
        class:list={[
          'inline-flex items-center gap-1.5 whitespace-nowrap rounded px-1.5 py-0.5',
          highlight && 'bg-primary/10 font-medium text-primary',
        ]}
      >
        <span class="size-3 shrink-0" aria-hidden="true" />
        <Icon name="lucide:folder" class="size-4 shrink-0 text-muted-foreground" />
        <span class="font-mono">{name}/</span>
        {comment && <span class="text-muted-foreground/75 ml-2">{comment}</span>}
      </span>
    </li>
  )
}
