---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<div class="step grid grid-cols-[1.75rem_1fr] gap-x-3 sm:grid-cols-[2rem_1fr] sm:gap-x-4">
  <div class="flex flex-col items-center">
    <div
      class="step-num bg-(--ctp-surface-1) leading-none text-foreground flex size-7 shrink-0 items-center justify-center rounded-full text-xs font-medium tabular-nums sm:size-8 sm:text-sm"
    >
    </div>
    <div class="step-connector w-px grow bg-(--ctp-surface-1)"></div>
  </div>
  <div class="step-content min-w-0 pb-6 pt-1 sm:pb-8">
    {
      title && (
        <span class="text-foreground mb-3 block text-base leading-tight sm:text-lg">{title}</span>
      )
    }
    <div class="prose max-w-none" data-step-content>
      <slot />
    </div>
  </div>
</div>

<style>
  [data-step-content] > :global(*:first-child) {
    margin-top: 0 !important;
  }
  [data-step-content] > :global(*:last-child) {
    margin-bottom: 0 !important;
  }

  .step {
    counter-increment: step;
  }

  .step-num::before {
    content: counter(step);
  }

  .step:last-child .step-connector {
    display: none;
  }

  .step:last-child .step-content {
    padding-bottom: 0;
  }
</style>
