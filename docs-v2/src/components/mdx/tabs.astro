---
import { codeToHtml } from 'shiki'

import { latte, mocha } from '@/lib/shiki-themes'

interface Props {
  items: string[]
  defaultIndex?: number
}

const { items, defaultIndex = 0 } = Astro.props

const ANNOT_RE = /\{:([a-z0-9]+)\}\s*$/i
const renderedItems = await Promise.all(
  items.map(async (label) => {
    const match = label.match(ANNOT_RE)
    if (!match || match.index === undefined) return { html: false as const, value: label }
    const code = label.slice(0, match.index).trim()
    const lang = match[1]
    const html = await codeToHtml(code, {
      lang,
      themes: { light: latte, dark: mocha },
      structure: 'inline',
    })
    return { html: true as const, value: html }
  }),
)
---

<div class="my-6 rounded-lg border-2" data-tabs>
  <div
    role="tablist"
    class="border-border bg-muted/30 flex gap-1 overflow-x-auto rounded-t-[6px] border-b-2 px-2 py-1.5 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
  >
    {
      renderedItems.map((item, i) => (
        <button
          type="button"
          role="tab"
          data-tab-index={i}
          aria-selected={i === defaultIndex}
          tabindex={i === defaultIndex ? 0 : -1}
          class="data-[selected=true]:bg-muted data-[selected=true]:text-foreground text-muted-foreground hover:text-foreground shrink-0 whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium transition-colors"
          data-selected={i === defaultIndex}
        >
          {item.html ? <span class="tab-label-code" set:html={item.value} /> : item.value}
        </button>
      ))
    }
  </div>
  <div data-tabs-panels class="p-4" data-default-index={defaultIndex}>
    <slot />
  </div>
</div>

<script>
  import { mountTabs } from '@/lib/client/tabs'

  mountTabs()
</script>
