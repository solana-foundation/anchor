---
import { ScrollArea } from '@/components/ui/scroll-area'
import { cn, getHeadingMargin } from '@/lib/utils'
import { renderDescription } from '@/lib/render-description'
import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
  minDepth?: number
  maxDepth?: number
  title?: string
  class?: string
}

const { headings, minDepth = 2, maxDepth = 4, title, class: className } = Astro.props
const renderedTitle = title ? await renderDescription(title) : null
const visible = headings.filter((h) => h.depth >= minDepth && h.depth <= maxDepth)
---

{
  visible.length > 0 && (
    <aside
      id="toc-sidebar-container"
      data-toc-sidebar-root
      class={cn('sticky top-16 hidden h-[calc(100vh-8rem)] max-w-xs flex-col xl:flex', className)}
    >
      {renderedTitle && (
        <div
          id="toc-sidebar-title-wrapper"
          data-open="false"
          class="grid shrink-0 grid-rows-[0fr] px-4 transition-[grid-template-rows] duration-200 ease-out data-[open=true]:grid-rows-[1fr]"
        >
          <div class="overflow-hidden">
            <span
              id="toc-sidebar-title"
              class="text-foreground block pb-3 text-base font-medium text-balance"
              data-doc-title
              set:html={renderedTitle.html}
            />
          </div>
        </div>
      )}
      <ScrollArea
        client:load
        className="min-h-0 flex-1 overflow-y-auto"
        type="hover"
        data-toc-scroll-area
      >
        <ul class="flex list-none flex-col gap-y-1.5 px-4">
          {visible.map((heading) => (
            <li
              data-toc-item={heading.slug}
              class={cn('text-sm text-foreground/60', getHeadingMargin(heading.depth))}
            >
              <a
                href={`#${heading.slug}`}
                data-heading-link={heading.slug}
                class="hover:text-foreground block underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit"
              >
                <span data-toc-text>{heading.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </ScrollArea>
    </aside>
  )
}

<style is:global>
  [data-toc-sidebar-root][data-toc-settling='true'],
  [data-toc-sidebar-root][data-toc-settling='true'] * {
    animation-duration: 0s !important;
    transition-duration: 0s !important;
    transition-property: none !important;
  }
</style>

<script>
  import {
    buildHeadingRegions,
    centerElementInScrollContainer,
    dataAttributeSelector,
    getContentHeadings,
    getVisibleHeadingIds,
    headingHtml,
    sameStringArray,
    setVerticalScrollMask,
    type HeadingRegion,
  } from '@/lib/client/toc'

  class TOCState {
    links: NodeListOf<Element> = document.querySelectorAll(
      '#toc-sidebar-container [data-heading-link]',
    )
    activeIds: string[] = []
    headings: HTMLElement[] = []
    regions: HeadingRegion[] = []
    scrollArea: HTMLElement | null = null
    tocScrollArea: HTMLElement | null = null

    reset() {
      this.links = document.querySelectorAll('#toc-sidebar-container [data-heading-link]')
      this.activeIds = []
      this.headings = []
      this.regions = []
      const tocContainer = document.getElementById('toc-sidebar-container')
      this.scrollArea = tocContainer?.querySelector('[data-radix-scroll-area-viewport]') || null
      this.tocScrollArea = tocContainer?.querySelector('[data-toc-scroll-area]') || null
    }
  }

  const state = new TOCState()

  class TOCTransitionGuard {
    static run(callback: () => void) {
      const roots = Array.from(document.querySelectorAll<HTMLElement>('[data-toc-sidebar-root]'))
      roots.forEach((root) => {
        root.dataset.tocSettling = 'true'
      })

      try {
        callback()
      } finally {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            roots.forEach((root) => {
              delete root.dataset.tocSettling
            })
          })
        })
      }
    }
  }

  class HeadingRegions {
    static build() {
      state.headings = getContentHeadings()
      state.regions = buildHeadingRegions(state.headings)
    }

    static getVisibleIds(): string[] {
      return getVisibleHeadingIds(state.headings, state.regions)
    }
  }

  class TOCScrollMask {
    static update() {
      if (!state.scrollArea || !state.tocScrollArea) return
      setVerticalScrollMask(state.scrollArea, state.tocScrollArea, {
        top: 'mask-t-from-90%',
        bottom: 'mask-b-from-90%',
      })
    }
  }

  class TOCLinks {
    static update(headingIds: string[]) {
      state.links.forEach((link) => {
        link.classList.remove('text-foreground')
      })

      headingIds.forEach((id) => {
        if (!id) return
        const activeLink = document.querySelector<HTMLElement>(
          `#toc-sidebar-container ${dataAttributeSelector('data-heading-link', id)}`,
        )
        if (activeLink) {
          activeLink.classList.add('text-foreground')
        }
      })

      this.scrollToActive(headingIds)
    }

    static scrollToActive(headingIds: string[]) {
      if (!state.scrollArea || !headingIds.length) return

      const activeLink = document.querySelector<HTMLElement>(
        `#toc-sidebar-container ${dataAttributeSelector('data-heading-link', headingIds[0])}`,
      )
      if (!activeLink) return

      centerElementInScrollContainer(state.scrollArea, activeLink)
    }
  }

  class TOCItemVisibility {
    static sync(visibleHeadings: HTMLElement[]) {
      const visibleIds = new Set(visibleHeadings.map((h) => h.id))
      document
        .querySelectorAll<HTMLElement>('#toc-sidebar-container [data-toc-item]')
        .forEach((item) => {
          const slug = item.dataset.tocItem
          item.hidden = !slug || !visibleIds.has(slug)
        })
    }
  }

  class TOCHeadingSync {
    // Pills longer than this in the narrow TOC column overflow when their
    // text has no break opportunities (e.g. `#[account(extensions::*)]`).
    // Mark them so CSS can opt them into `overflow-wrap: anywhere` — which
    // we don't want universally, since short pills look better unbroken.
    static LONG_PILL = 24

    static run() {
      state.links.forEach((link) => {
        const slug = (link as HTMLElement).dataset.headingLink
        if (!slug) return
        const heading = document.getElementById(slug)
        if (!heading) return
        const target = link.querySelector<HTMLElement>('[data-toc-text]')
        if (!target) return
        target.innerHTML = headingHtml(heading, {
          longPillThreshold: TOCHeadingSync.LONG_PILL,
        })
      })
    }
  }

  class TOCController {
    static visibilityObserver: MutationObserver | null = null

    static handleScroll() {
      const newActiveIds = HeadingRegions.getVisibleIds()

      if (!sameStringArray(newActiveIds, state.activeIds)) {
        state.activeIds = newActiveIds
        TOCLinks.update(state.activeIds)
      }
    }

    static handleTOCScroll = () => TOCScrollMask.update()

    static handleResize() {
      HeadingRegions.build()
      const newActiveIds = HeadingRegions.getVisibleIds()

      if (!sameStringArray(newActiveIds, state.activeIds)) {
        state.activeIds = newActiveIds
        TOCLinks.update(state.activeIds)
      }

      // Sync visibility AFTER the active class is on the <a>, so a newly
      // un-hidden <li> already shows in its final highlighted state instead
      // of animating from gray → white via transition-colors.
      TOCItemVisibility.sync(state.headings)

      TOCScrollMask.update()
    }

    static observeVisibilityChanges() {
      // Tabs toggle `hidden` on panels and <details> toggles `open`. Either can
      // un-hide a heading, which changes its offsetTop and invalidates the
      // cached region map — rebuild on those mutations.
      const root = document.querySelector('.prose')
      if (!root) return

      this.visibilityObserver = new MutationObserver((mutations) => {
        const relevant = mutations.some(
          (m) =>
            m.type === 'attributes' && (m.attributeName === 'hidden' || m.attributeName === 'open'),
        )
        if (relevant) this.handleResize()
      })

      this.visibilityObserver.observe(root, {
        subtree: true,
        attributes: true,
        attributeFilter: ['hidden', 'open'],
      })
    }

    static init() {
      state.reset()
      let hasHeadings = false

      TOCTransitionGuard.run(() => {
        TOCHeadingSync.run()
        HeadingRegions.build()
        TOCTitleVisibility.init()
        hasHeadings = state.headings.length > 0

        if (!hasHeadings) {
          TOCLinks.update([])
          TOCItemVisibility.sync([])
          return
        }

        this.handleScroll()
        TOCItemVisibility.sync(state.headings)
      })

      if (!hasHeadings) return

      setTimeout(TOCScrollMask.update, 100)

      const options = { passive: true }
      window.addEventListener('scroll', this.handleScroll, options)
      window.addEventListener('resize', this.handleResize, options)
      state.scrollArea?.addEventListener('scroll', this.handleTOCScroll, options)
      this.observeVisibilityChanges()
    }

    static cleanup() {
      window.removeEventListener('scroll', this.handleScroll)
      window.removeEventListener('resize', this.handleResize)
      state.scrollArea?.removeEventListener('scroll', this.handleTOCScroll)
      TOCTitleVisibility.cleanup()
      this.visibilityObserver?.disconnect()
      this.visibilityObserver = null

      Object.assign(state, {
        activeIds: [],
        headings: [],
        regions: [],
        scrollArea: null,
        tocScrollArea: null,
      })
    }
  }

  class TOCTitleVisibility {
    static observer: IntersectionObserver | null = null

    static init() {
      const wrapper = document.getElementById('toc-sidebar-title-wrapper')
      const heading = document.getElementById('post-title')
      if (!wrapper || !heading) return

      this.cleanup()

      this.observer = new IntersectionObserver(
        (entries) => {
          const entry = entries[0]
          if (!entry) return
          wrapper.dataset.open =
            !entry.isIntersecting && entry.boundingClientRect.bottom <= 0 ? 'true' : 'false'
        },
        { rootMargin: '0px', threshold: 0 },
      )

      this.observer.observe(heading)
    }

    static cleanup() {
      this.observer?.disconnect()
      this.observer = null
    }
  }

  document.addEventListener('astro:page-load', () => TOCController.init())
  document.addEventListener('astro:after-swap', () => {
    TOCController.cleanup()
    TOCController.init()
  })
  document.addEventListener('astro:before-swap', () => TOCController.cleanup())
</script>
